{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Backend: FastAPI (Uvicorn)",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "cwd": "${workspaceFolder}/backend",
      "args": [
        "app.main:app",
        "--host",
        "0.0.0.0",
        "--port",
        "8000",
        "--reload"
      ],
      "envFile": "${workspaceFolder}/backend/.env"
    },
    {
      "name": "Backend: Pytest",
      "type": "debugpy",
      "request": "launch",
      "module": "pytest",
      "cwd": "${workspaceFolder}/backend",
      "args": [
        "-q"
      ],
      "console": "integratedTerminal"
    },
    {
      "name": "Frontend: Next.js Dev",
      "type": "node-terminal",
      "request": "launch",
      "command": "npm run dev",
      "cwd": "${workspaceFolder}/frontend"
    }
  ],
  "compounds": [
    {
      "name": "TraderPulse Full Stack",
      "configurations": [
        "Backend: FastAPI (Uvicorn)",
        "Frontend: Next.js Dev"
      ]
    }
  ]
}
